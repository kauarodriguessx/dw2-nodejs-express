<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Bem viando a area de produtos</h1>
    
    <hr>

    <!-- Exibindo uma variavel JavaScript dentro do HTML-->
     
    <!-- Comentário no EJS <%# %>-->


    <!-- Percorrendo o vetor através do forEach -->

    <% listaProdutos.forEach(function(produto) { %>
        <p>
            <a href="produtos/<%= produto %>">
             <%= produto %> 

             </a>

        
        
        </p>

    <% }) %>

    <p><a href="/">Voltar para o inicio</a></p>
</body>
</html>